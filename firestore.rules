rules_version = '2';
// ═══════════════════════════════════════════════════════════════════════
// CrossTainer — Firestore Security Rules
// Cobre módulo de Comissões (existente) + Módulo de Professores (novo)
// Spec: §12 do EspecificacaoTecnica_Modulo_Professores_CrossTainer_V1.md
// ═══════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function uData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica se usuário tem perfil específico
    // Backward compatible: aceita tanto profiles[] (novo) quanto role (antigo)
    function hasP(p) {
      let u = uData();
      return (u.profiles != null && p in u.profiles) || u.role == p;
    }

    function isAdmin()      { return hasP('admin'); }   // admin_gestao dropado (hub Pessoas D2)
    function isStrictAdmin(){ return hasP('admin'); }
    function isSuperv()     { return hasP('supervisao'); }
    function isProf()       { return hasP('professor') || hasP('professor_estagiario'); }

    function hasProfModule() { return isAdmin() || isSuperv() || isProf(); }
    function hasComModule()  {
      let u = uData();
      return u.role == 'admin' || u.role == 'vendedor' ||
             (u.moduleAccess != null && u.moduleAccess.comissoes == true);
    }

    // ─── COLEÇÕES EXISTENTES (módulo de Comissões) ────────────────────
    match /users/{uid} {
      allow read:   if isAuth() && (request.auth.uid == uid || isAdmin());
      allow create: if isAuth() && isAdmin();
      allow update: if isAuth() && (
                       isAdmin() ||
                       // próprio usuário pode atualizar profiles e moduleAccess apenas durante migração inline
                       (request.auth.uid == uid &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['profiles', 'moduleAccess', 'updatedAt']))
                     );
      allow delete: if false;
    }

    match /units/{id} {
      allow read:  if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    match /periodos/{id} {
      allow read, write: if isAuth() && hasComModule();
      match /itens/{i} {
        allow read, write: if isAuth() && hasComModule();
      }
    }

    match /comissoes_diferidas/{id} {
      allow read, write: if isAuth() && hasComModule();
    }

    match /audit_log/{id} {
      allow read:           if isAuth() && isAdmin();
      allow create:         if isAuth();
      allow update, delete: if false;
    }

    // ─── COLEÇÕES NOVAS (módulo de Professores) ───────────────────────

    // ⛔ Dados salariais — APENAS Admin
    match /teacher_salaries/{id} {
      allow read, write: if isAuth() && isAdmin();
    }

    match /teachers/{id} {
      allow read:   if isAuth() && hasProfModule();
      allow create: if isAuth() && isAdmin();                  // D9: só admin cria (wizard)
      allow update: if isAuth() && (isAdmin() || isSuperv());  // D5: supervisão edita Identidade/Professor
      allow delete: if false;
    }

    match /modalities/{id} {
      allow read:  if isAuth() && hasProfModule();
      allow write: if isAuth() && isAdmin();
    }

    match /schedule_templates/{id} {
      allow read:  if isAuth() && hasProfModule();
      allow write: if isAuth() && (isAdmin() || isSuperv());
    }

    match /schedule_slots/{id} {
      allow read:  if isAuth() && hasProfModule();
      allow write: if isAuth() && (isAdmin() || isSuperv());
    }

    match /classes/{id} {
      allow read:   if isAuth() && hasProfModule();
      allow create: if isAuth() && (isAdmin() || isSuperv());
      // Professor só pode atualizar a aula que é DELE e que não foi fechada
      allow update: if isAuth() && (
                      isAdmin() || isSuperv() ||
                      (isProf() &&
                       resource.data.originalTeacherId == uData().professorId &&
                       resource.data.monthClosingId == null)
                    );
      // Despublicar escala: gestão apaga SÓ aulas geradas pela escala e não fechadas
      allow delete: if isAuth() && (isAdmin() || isSuperv()) &&
                       resource.data.specialScaleId is string &&
                       resource.data.monthClosingId == null;
    }

    match /substitutions/{id} {
      allow read:   if isAuth() && hasProfModule();
      allow create: if isAuth() && hasProfModule();
      allow update: if isAuth() && (
                      isAdmin() || isSuperv() ||
                      resource.data.requestingUserId == request.auth.uid ||
                      resource.data.substituteUserId == request.auth.uid
                    );
      allow delete: if false;
    }

    match /coverage_applications/{id} {
      allow read:   if isAuth() && hasProfModule();
      allow create: if isAuth() && hasProfModule();
      allow update: if isAuth() && (isAdmin() || isSuperv());
    }

    match /monthly_closings/{id} {
      allow read:   if isAuth() && hasProfModule();
      allow create: if isAuth() && isStrictAdmin();
      // ⛔ Não pode alterar mês fechado
      allow update: if isAuth() && isAdmin() && resource.data.status != 'fechado';
      allow delete: if false;
    }

    match /creditos_professores/{id} {
      allow read:  if isAuth() && (
                     isAdmin() ||
                     resource.data.teacherId == uData().professorId
                   );
      allow write: if isAuth() && isStrictAdmin();
      allow delete: if false;
    }

    match /meta/receipt_counter {
      allow read:  if isAuth() && isAdmin();
      allow write: if isAuth() && isStrictAdmin();
    }

    match /payment_records/{id} {
      allow read:  if isAuth() && (
                     isAdmin() ||
                     resource.data.teacherId == uData().professorId
                   );
      allow write: if isAuth() && isStrictAdmin();
    }

    match /receipts/{id} {
      allow read:  if isAuth() && (
                     isAdmin() ||
                     resource.data.teacherId == uData().professorId
                   );
      allow write: if isAuth() && isStrictAdmin();
    }

    match /special_scale_types/{id} {
      allow read:  if isAuth() && hasProfModule();
      allow write: if isAuth() && isAdmin();
    }

    // (bloco antigo de special_scales + subcoleção scale_responses removido na
    //  auditoria 2026-07-02: era duplicata do bloco da escala inteligente abaixo
    //  e o `allow write` reabria o delete que o outro bloco fecha. scale_responses
    //  não é usada por nenhum JS. Ver docs/superpowers/audits/2026-07-02-*.)

    // ─── Engajamento / Pontos (módulo novo) ───────────────────────────
    // Config calibrável dos pontos + ciclos de reset: leitura p/ todo o módulo
    // (professor precisa pra ver o próprio placar), escrita só admin.
    match /engagement_config/{id} {
      allow read:  if isAuth() && hasProfModule();
      allow write: if isAuth() && isAdmin();
    }

    match /point_cycles/{id} {
      allow read:  if isAuth() && hasProfModule();
      allow write: if isAuth() && isAdmin();
    }

    // Livro-razão dos pontos: professor lê só os DELE; gestão lança (ticando
    // chamada / confirmando reunião / creditando substituição). Sem delete
    // (preserva trilha; limpeza de órfãs será operação admin futura).
    match /point_entries/{id} {
      allow read:   if isAuth() && (
                      isAdmin() || isSuperv() ||
                      resource.data.personId == uData().professorId
                    );
      allow create, update: if isAuth() && (isAdmin() || isSuperv());
      allow delete: if false;
    }

    // Chamadas (escola interna / reunião / treinamento / evento): leitura p/ o
    // módulo, escrita pela gestão. (Self-mark de reunião pelo colaborador será
    // refinado quando a tela de reunião for construída.)
    match /attendance/{id} {
      allow read:   if isAuth() && hasProfModule();
      allow create, update: if isAuth() && (isAdmin() || isSuperv());
      allow delete: if false;
    }

    // ─── Escala inteligente (sábados/feriados) ─────────────────────────
    // Escalas + slots tipados: leitura p/ o módulo, escrita pela gestão.
    match /special_scales/{id} {
      allow read:   if isAuth() && hasProfModule();
      allow create, update: if isAuth() && (isAdmin() || isSuperv());
      allow delete: if false;
    }

    // Preferências de escala: o colaborador grava a SUA (personId == professorId);
    // gestão grava qualquer uma. Doc id = `${scaleId}__${personId}`.
    match /scale_preferences/{id} {
      allow read:   if isAuth() && hasProfModule();
      allow create, update: if isAuth() && (
                      isAdmin() || isSuperv() ||
                      request.resource.data.personId == uData().professorId
                    );
      allow delete: if false;
    }

    // Preferência por data do fim de ano: colaborador grava a SUA (personId == professorId);
    // gestão grava qualquer uma. Doc id = `${scaleId}__${personId}__${date}`.
    match /scale_day_preferences/{id} {
      allow read:   if isAuth() && hasProfModule();
      allow create, update: if isAuth() && (
                      isAdmin() || isSuperv() ||
                      request.resource.data.personId == uData().professorId
                    );
      allow delete: if false;
    }

    // Contador de justiça/compensação: leitura p/ o módulo, escrita pela gestão
    // (atualizado na consolidação). Sem delete.
    match /fairness_counter/{id} {
      allow read:  if isAuth() && hasProfModule();
      allow write: if isAuth() && (isAdmin() || isSuperv());
      allow delete: if false;
    }

    // Config da escala (horários-padrão das vagas) — leitura do módulo, escrita admin
    match /scale_config/{id} {
      allow read:  if isAuth() && hasProfModule();
      allow write: if isAuth() && isAdmin();
    }

    // ─── PLR (avaliação de desempenho) — dado SENSÍVEL (valores/notas) ───
    // config: leitura do módulo (pesos/blocos), escrita admin.
    match /plr_config/{id} {
      allow read:  if isAuth() && hasProfModule();
      allow write: if isAuth() && isAdmin();
    }
    // ciclos e resultados (pool/fatias) = só gestão.
    match /plr_cycles/{id} {
      allow read:  if isAuth() && (isAdmin() || isSuperv());
      allow write: if isAuth() && isAdmin();
    }
    match /plr_results/{id} {
      allow read:  if isAuth() && (isAdmin() || isSuperv());
      allow write: if isAuth() && isAdmin();
    }
    // avaliações: notas individuais sensíveis. Lê gestão; grava o próprio avaliador ou gestão; sem delete.
    match /plr_evaluations/{id} {
      allow read:   if isAuth() && (isAdmin() || isSuperv());
      allow create, update: if isAuth() && (isAdmin() || isSuperv() ||
                       request.resource.data.evaluatorId == request.auth.uid);
      allow delete: if false;
    }

    // Cache de feriados nacionais (meta/holidays_cache_*) — apenas CF escreve via Admin SDK
    match /meta/{doc} {
      allow read:  if isAuth() && hasProfModule() && doc.matches('holidays_cache_.*');
      allow write: if false;
    }

    match /vacation_requests/{id} {
      allow read: if isAuth() && (
        isAdmin() || isSuperv() ||
        resource.data.teacherId == uData().professorId
      );
      allow create: if isAuth() && hasProfModule()
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.status == 'pendente';
      allow update: if isAuth() && (
        // (A) Mudanças que tocam payment ou paidInClosingIds
        // APENAS admin/admin_gestao (supervisor NÃO)
        // Só permitido enquanto paidInClosingIds vazio
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['payment', 'paidInClosingIds'])
          && isAdmin()
          && (!('paidInClosingIds' in resource.data) || resource.data.paidInClosingIds.size() == 0)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['payment', 'paidInClosingIds', 'updatedAt'])
        )
        ||
        // (B) Mudanças de status (admin, admin_gestao, supervisor)
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['payment', 'paidInClosingIds'])
          && (isAdmin() || isSuperv())
        )
        ||
        // (C) Solicitante cancelando pendente (6a — manter como está)
        (resource.data.requestedBy == request.auth.uid
         && resource.data.status == 'pendente'
         && request.resource.data.status == 'cancelada'
         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt', 'cancelledBy', 'cancelledByName', 'cancelledReason', 'updatedAt']))
      );
      allow delete: if false;
    }

    match /notifications/{id} {
      allow read, update: if isAuth() &&
                            resource.data.recipientUserId == request.auth.uid;
      allow create:       if isAuth();
      allow delete:       if false;
    }

    // ─── Coleção do Trigger Email (Firebase Extension) ─────────────────
    match /mail/{id} {
      // Apenas Cloud Functions escrevem aqui (via Admin SDK)
      // Frontend nunca grava direto — sempre via CF que cria notification + envia
      allow read, write: if false;
    }

    // ─── Default deny ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
